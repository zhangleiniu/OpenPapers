{
  "schema_version": 1,
  "scheduling": {
    "unknown_schedule_interval_days": 60,
    "verified_milestone_lead_days": 30,
    "post_conference_release_backoff_days": [0, 1, 3, 7, 14, 30],
    "max_silence_days": 90,
    "minimum_recheck_interval_hours": 6
  },
  "reminders": {
    "immediate_on_first_observation": true,
    "weekly_interval_days": 7,
    "weekly_until_days": 28,
    "monthly_interval_days": 30,
    "monthly_until_days": 84,
    "dormant_after_days": 84,
    "dormant_interval_days": 90
  },
  "discovery_budget": {
    "max_calls_per_day": 20,
    "max_calls_per_venue_per_day": 20,
    "max_concurrency": 2,
    "max_second_provider_calls_per_day": 5
  },
  "automatic_discovery": {
    "same_failure_cooldown_hours": 6,
    "systemic_circuit_hours": 24
  },
  "codex_budget": {
    "max_runs_per_day": 3,
    "max_runs_per_venue_per_day": 1,
    "max_concurrency": 1,
    "same_error_cooldown_days": 7,
    "max_runtime_minutes": 60,
    "allow_recursive_trigger": false
  },
  "systemic_failure": {
    "venue_failure_threshold": 3,
    "suppress_per_venue_codex": true,
    "single_incident_notification": true
  },
  "crawl": {
    "default_classification": "review_required",
    "domains": []
  },
  "publication": {
    "default_pdf_delivery": "authoritative_link",
    "redistribute_metadata_without_review": false,
    "redistribute_pdf_without_review": false
  }
}
