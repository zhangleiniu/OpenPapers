{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openpapers.local/schemas/v1/case-state.json",
  "title": "OpenPapers unresolved case state v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "case_id",
    "venue_id",
    "year",
    "blocker",
    "status",
    "summary",
    "evidence_ids",
    "first_observed_at",
    "last_checked_at",
    "last_meaningful_change_at",
    "snoozed_until",
    "resolution"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "case_id": {"$ref": "#/$defs/id"},
    "venue_id": {"$ref": "#/$defs/venue_id"},
    "year": {"type": "integer", "minimum": 1900, "maximum": 2200},
    "blocker": {"$ref": "#/$defs/blocker"},
    "status": {
      "enum": ["open", "stalled", "dormant", "snoozed", "resolved", "ignored", "wont_fix"]
    },
    "summary": {"type": "string", "minLength": 1, "maxLength": 5000},
    "evidence_ids": {
      "type": "array",
      "items": {"$ref": "#/$defs/id"},
      "uniqueItems": true
    },
    "first_observed_at": {"type": "string", "format": "date-time"},
    "last_checked_at": {"type": "string", "format": "date-time"},
    "last_meaningful_change_at": {"type": "string", "format": "date-time"},
    "snoozed_until": {"type": ["string", "null"], "format": "date-time"},
    "resolution": {"type": ["string", "null"], "maxLength": 5000}
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]{2,127}$"
    },
    "venue_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,31}$"
    },
    "blocker": {
      "enum": [
        "no_public_list",
        "no_pdf",
        "unknown_download_source",
        "unsupported_scraper",
        "scraper_failed",
        "validation_failed",
        "agent_pending",
        "codex_patch_pending",
        "human_review_required",
        "crawl_policy_denied"
      ]
    }
  }
}
