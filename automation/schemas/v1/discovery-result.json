{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openpapers.local/schemas/v1/discovery-result.json",
  "title": "OpenPapers discovery result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "discovery_id",
    "venue_id",
    "year",
    "checked_at",
    "provider",
    "model",
    "prompt_version",
    "conference_status",
    "paper_list_status",
    "metadata_status",
    "pdf_status",
    "proceedings_status",
    "claims",
    "confidence",
    "uncertainties",
    "evidence_fingerprint"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "discovery_id": {"$ref": "#/$defs/id"},
    "venue_id": {"$ref": "#/$defs/venue_id"},
    "year": {"type": "integer", "minimum": 1900, "maximum": 2200},
    "checked_at": {"type": "string", "format": "date-time"},
    "provider": {"type": "string", "minLength": 1, "maxLength": 100},
    "model": {"type": "string", "minLength": 1, "maxLength": 200},
    "prompt_version": {"type": "string", "pattern": "^v[1-9][0-9]*$"},
    "conference_status": {
      "enum": ["unknown", "scheduled", "ended"]
    },
    "paper_list_status": {
      "enum": ["unknown", "unavailable", "partial", "released"]
    },
    "metadata_status": {
      "enum": ["unknown", "unavailable", "partial", "ready"]
    },
    "pdf_status": {
      "enum": ["unknown", "unavailable", "partial", "ready"]
    },
    "proceedings_status": {
      "enum": ["unknown", "unavailable", "provisional", "archival"]
    },
    "claims": {
      "type": "array",
      "items": {"$ref": "#/$defs/claim"},
      "maxItems": 500
    },
    "candidate_milestones": {
      "type": "array",
      "items": {"$ref": "#/$defs/candidate_milestone"},
      "maxItems": 50
    },
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "uncertainties": {
      "type": "array",
      "items": {"type": "string", "minLength": 1, "maxLength": 1000},
      "uniqueItems": true,
      "maxItems": 100
    },
    "evidence_fingerprint": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]{2,127}$"
    },
    "venue_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,31}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_id",
        "statement",
        "evidence_urls",
        "source_type",
        "published_at"
      ],
      "properties": {
        "claim_id": {"$ref": "#/$defs/id"},
        "claim_kind": {
          "enum": [
            "conference",
            "paper_list",
            "metadata",
            "pdf",
            "proceedings",
            "other"
          ]
        },
        "statement": {"type": "string", "minLength": 1, "maxLength": 5000},
        "evidence_urls": {
          "type": "array",
          "items": {"type": "string", "format": "uri", "pattern": "^https://"},
          "minItems": 1,
          "maxItems": 20,
          "uniqueItems": true
        },
        "source_type": {
          "enum": ["official", "archival", "secondary", "search_result"]
        },
        "published_at": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      }
    },
    "candidate_milestone": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "milestone_id",
        "milestone_type",
        "date",
        "evidence_urls",
        "source_type"
      ],
      "properties": {
        "milestone_id": {"$ref": "#/$defs/id"},
        "milestone_type": {
          "enum": [
            "conference_start",
            "conference_end",
            "acceptance_notification",
            "paper_list_expected",
            "proceedings_expected"
          ]
        },
        "scope": {
          "enum": ["conference", "main_track"]
        },
        "date": {"type": "string", "format": "date"},
        "evidence_urls": {
          "type": "array",
          "items": {"type": "string", "format": "uri", "pattern": "^https://"},
          "minItems": 1,
          "maxItems": 20,
          "uniqueItems": true
        },
        "source_type": {
          "enum": ["official", "archival", "secondary", "search_result"]
        }
      }
    }
  }
}
