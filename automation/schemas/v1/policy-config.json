{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openpapers.local/schemas/v1/policy-config.json",
  "title": "Discovery policy configuration v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "discovery_budget"],
  "properties": {
    "schema_version": {"const": 1},
    "discovery_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_calls_per_day",
        "max_calls_per_venue_per_day",
        "max_concurrency",
        "max_second_provider_calls_per_day"
      ],
      "properties": {
        "max_calls_per_day": {"type": "integer", "minimum": 1, "maximum": 1000},
        "max_calls_per_venue_per_day": {"type": "integer", "minimum": 1, "maximum": 1000},
        "max_concurrency": {"type": "integer", "minimum": 1, "maximum": 16},
        "max_second_provider_calls_per_day": {"type": "integer", "minimum": 0, "maximum": 1000}
      }
    }
  }
}
