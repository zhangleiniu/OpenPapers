{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openpapers.local/schemas/v1/validation-report.json",
  "title": "OpenPapers independent validation report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "report_id",
    "report_fingerprint",
    "validation_job_id",
    "validation_job_fingerprint",
    "scrape_job_id",
    "candidate_manifest_id",
    "candidate_inventory_fingerprint",
    "venue_id",
    "year",
    "validated_at",
    "completeness_level",
    "require_pdfs",
    "expected_count",
    "status",
    "metrics",
    "issues"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "report_id": {"type": "string", "pattern": "^validation:[a-f0-9]{64}$"},
    "report_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "validation_job_id": {"type": "string", "pattern": "^job:[a-f0-9]{64}$"},
    "validation_job_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "scrape_job_id": {"type": "string", "pattern": "^job:[a-f0-9]{64}$"},
    "candidate_manifest_id": {"type": "string", "pattern": "^manifest:[a-f0-9]{64}$"},
    "candidate_inventory_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "venue_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,31}$"},
    "year": {"type": "integer", "minimum": 1900, "maximum": 2200},
    "validated_at": {"type": "string", "format": "date-time"},
    "completeness_level": {"enum": ["announced", "metadata", "archival"]},
    "require_pdfs": {"type": "boolean"},
    "expected_count": {"type": ["integer", "null"], "minimum": 1},
    "status": {"enum": ["valid", "invalid"]},
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["paper_count", "valid_pdf_count"],
      "properties": {
        "paper_count": {"type": "integer", "minimum": 0},
        "valid_pdf_count": {"type": ["integer", "null"], "minimum": 0}
      }
    },
    "issues": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "paper_count": {"$ref": "#/$defs/count"},
        "duplicate_ids": {"$ref": "#/$defs/count"},
        "missing_id": {"$ref": "#/$defs/count"},
        "missing_title": {"$ref": "#/$defs/count"},
        "missing_authors": {"$ref": "#/$defs/count"},
        "missing_year": {"$ref": "#/$defs/count"},
        "missing_conference": {"$ref": "#/$defs/count"},
        "missing_url": {"$ref": "#/$defs/count"},
        "missing_bibtex": {"$ref": "#/$defs/count"},
        "missing_abstract": {"$ref": "#/$defs/count"},
        "missing_pdf_url": {"$ref": "#/$defs/count"},
        "provisional": {"$ref": "#/$defs/count"},
        "missing_pdf_path": {"$ref": "#/$defs/count"},
        "missing_pdf_file": {"$ref": "#/$defs/count"},
        "undersized_pdf": {"$ref": "#/$defs/count"},
        "invalid_pdf_signature": {"$ref": "#/$defs/count"},
        "unreadable_pdf": {"$ref": "#/$defs/count"}
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "valid"}}},
      "then": {"properties": {"issues": {"maxProperties": 0}}},
      "else": {"properties": {"issues": {"minProperties": 1}}}
    },
    {
      "if": {"properties": {"require_pdfs": {"const": true}}},
      "then": {
        "properties": {
          "metrics": {
            "properties": {"valid_pdf_count": {"type": "integer", "minimum": 0}}
          }
        }
      },
      "else": {
        "properties": {
          "metrics": {"properties": {"valid_pdf_count": {"type": "null"}}}
        }
      }
    }
  ],
  "$defs": {
    "count": {"type": "integer", "minimum": 1}
  }
}
