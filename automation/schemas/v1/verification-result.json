{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openpapers.local/schemas/v1/verification-result.json",
  "title": "OpenPapers verification result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "verification_id",
    "request_id",
    "discovery_id",
    "venue_id",
    "year",
    "verified_at",
    "overall_status",
    "source_observations",
    "findings",
    "verified_facets",
    "verified_milestones",
    "uncertainties",
    "evidence_fingerprint"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "verification_id": {"$ref": "#/$defs/id"},
    "request_id": {"$ref": "#/$defs/id"},
    "discovery_id": {"$ref": "#/$defs/id"},
    "venue_id": {"$ref": "#/$defs/venue_id"},
    "year": {"type": "integer", "minimum": 1900, "maximum": 2200},
    "verified_at": {"type": "string", "format": "date-time"},
    "overall_status": {
      "enum": [
        "verified",
        "partially_verified",
        "rejected",
        "review_required",
        "conflicting",
        "error"
      ]
    },
    "source_observations": {
      "type": "array",
      "items": {"$ref": "#/$defs/source_observation"},
      "maxItems": 1000
    },
    "findings": {
      "type": "array",
      "items": {"$ref": "#/$defs/finding"},
      "maxItems": 1000
    },
    "verified_facets": {"$ref": "#/$defs/verified_facets"},
    "verified_milestones": {
      "type": "array",
      "items": {"$ref": "#/$defs/verified_milestone"},
      "uniqueItems": true,
      "maxItems": 50
    },
    "uncertainties": {
      "type": "array",
      "items": {"type": "string", "minLength": 1, "maxLength": 1000},
      "uniqueItems": true,
      "maxItems": 100
    },
    "evidence_fingerprint": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]{2,127}$"
    },
    "venue_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,31}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "https_uri": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://"
    },
    "permission": {
      "enum": [
        "monitor",
        "metadata_fetch",
        "pdf_fetch_for_processing",
        "store_internal_copy",
        "redistribute_metadata",
        "redistribute_pdf"
      ]
    },
    "verification_kind": {
      "enum": [
        "source_identity",
        "conference_milestone",
        "paper_list",
        "metadata",
        "proceedings",
        "pdf"
      ]
    },
    "source_observation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "url",
        "source_trust",
        "policy_decision",
        "policy_domain",
        "permission",
        "fetch_status",
        "http_status",
        "snapshot_id",
        "observed_at",
        "reason_code"
      ],
      "properties": {
        "source_id": {"$ref": "#/$defs/id"},
        "url": {"$ref": "#/$defs/https_uri"},
        "source_trust": {
          "enum": ["official", "archival", "untrusted"]
        },
        "policy_decision": {
          "enum": [
            "allowed",
            "review_required",
            "denied",
            "permission_missing",
            "request_budget_exhausted"
          ]
        },
        "policy_domain": {"type": ["string", "null"], "maxLength": 253},
        "permission": {"$ref": "#/$defs/permission"},
        "fetch_status": {
          "enum": ["not_attempted", "fetched", "failed"]
        },
        "http_status": {
          "type": ["integer", "null"],
          "minimum": 100,
          "maximum": 599
        },
        "snapshot_id": {
          "oneOf": [{"$ref": "#/$defs/id"}, {"type": "null"}]
        },
        "observed_at": {"type": ["string", "null"], "format": "date-time"},
        "reason_code": {
          "enum": [
            "source_observed",
            "policy_review_required",
            "crawl_denied",
            "permission_missing",
            "request_budget_exhausted",
            "fetch_failed"
          ]
        }
      },
      "allOf": [
        {
          "if": {"properties": {"fetch_status": {"const": "not_attempted"}}},
          "then": {
            "properties": {
              "http_status": {"type": "null"},
              "snapshot_id": {"type": "null"},
              "observed_at": {"type": "null"}
            }
          }
        },
        {
          "if": {"properties": {"fetch_status": {"const": "fetched"}}},
          "then": {
            "properties": {
              "policy_decision": {"const": "allowed"},
              "http_status": {"type": "integer"},
              "snapshot_id": {"$ref": "#/$defs/id"},
              "observed_at": {"type": "string", "format": "date-time"},
              "reason_code": {"const": "source_observed"}
            }
          }
        },
        {
          "if": {"properties": {"fetch_status": {"const": "failed"}}},
          "then": {
            "properties": {
              "policy_decision": {"const": "allowed"},
              "snapshot_id": {"type": "null"},
              "reason_code": {"const": "fetch_failed"}
            }
          }
        },
        {
          "if": {
            "not": {"properties": {"policy_decision": {"const": "allowed"}}}
          },
          "then": {"properties": {"fetch_status": {"const": "not_attempted"}}}
        }
      ]
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_id",
        "target_kind",
        "target_id",
        "verification_kind",
        "status",
        "source_ids",
        "evidence_ids",
        "reason_code",
        "metrics"
      ],
      "properties": {
        "finding_id": {"$ref": "#/$defs/id"},
        "target_kind": {"enum": ["claim", "candidate_milestone"]},
        "target_id": {"$ref": "#/$defs/id"},
        "verification_kind": {"$ref": "#/$defs/verification_kind"},
        "status": {
          "enum": [
            "verified",
            "rejected",
            "review_required",
            "conflicting",
            "error"
          ]
        },
        "source_ids": {
          "type": "array",
          "items": {"$ref": "#/$defs/id"},
          "uniqueItems": true
        },
        "evidence_ids": {
          "type": "array",
          "items": {"$ref": "#/$defs/id"},
          "uniqueItems": true
        },
        "reason_code": {
          "enum": [
            "supported",
            "policy_review_required",
            "crawl_denied",
            "permission_missing",
            "fetch_failed",
            "redirect_review_required",
            "identity_mismatch",
            "year_mismatch",
            "implausible_paper_count",
            "metadata_incomplete",
            "proceedings_not_found",
            "pdf_invalid_url",
            "pdf_http_status",
            "pdf_too_small",
            "pdf_signature_invalid",
            "pdf_sample_incomplete",
            "conflicting_evidence",
            "unsupported_source_shape"
          ]
        },
        "metrics": {
          "oneOf": [{"$ref": "#/$defs/metrics"}, {"type": "null"}]
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "paper_count": {"type": "integer", "minimum": 0},
        "metadata_complete_count": {"type": "integer", "minimum": 0},
        "pdf_sampled_count": {"type": "integer", "minimum": 0},
        "pdf_valid_count": {"type": "integer", "minimum": 0}
      },
      "minProperties": 1
    },
    "verified_facets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "conference_status",
        "paper_list_status",
        "metadata_status",
        "pdf_status",
        "proceedings_status"
      ],
      "properties": {
        "conference_status": {
          "$ref": "#/$defs/nullable_conference_facet"
        },
        "paper_list_status": {"$ref": "#/$defs/nullable_paper_list_facet"},
        "metadata_status": {"$ref": "#/$defs/nullable_metadata_facet"},
        "pdf_status": {"$ref": "#/$defs/nullable_pdf_facet"},
        "proceedings_status": {"$ref": "#/$defs/nullable_proceedings_facet"}
      }
    },
    "facet_base": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "evidence_ids"],
      "properties": {
        "value": {"type": "string"},
        "evidence_ids": {
          "type": "array",
          "items": {"$ref": "#/$defs/id"},
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "conference_facet": {
      "allOf": [
        {"$ref": "#/$defs/facet_base"},
        {"properties": {"value": {"enum": ["scheduled", "ended"]}}}
      ]
    },
    "paper_list_facet": {
      "allOf": [
        {"$ref": "#/$defs/facet_base"},
        {"properties": {"value": {"enum": ["partial", "released"]}}}
      ]
    },
    "metadata_facet": {
      "allOf": [
        {"$ref": "#/$defs/facet_base"},
        {"properties": {"value": {"enum": ["partial", "ready"]}}}
      ]
    },
    "pdf_facet": {
      "allOf": [
        {"$ref": "#/$defs/facet_base"},
        {"properties": {"value": {"enum": ["partial", "ready"]}}}
      ]
    },
    "proceedings_facet": {
      "allOf": [
        {"$ref": "#/$defs/facet_base"},
        {"properties": {"value": {"enum": ["provisional", "archival"]}}}
      ]
    },
    "nullable_conference_facet": {
      "oneOf": [{"$ref": "#/$defs/conference_facet"}, {"type": "null"}]
    },
    "nullable_paper_list_facet": {
      "oneOf": [{"$ref": "#/$defs/paper_list_facet"}, {"type": "null"}]
    },
    "nullable_metadata_facet": {
      "oneOf": [{"$ref": "#/$defs/metadata_facet"}, {"type": "null"}]
    },
    "nullable_pdf_facet": {
      "oneOf": [{"$ref": "#/$defs/pdf_facet"}, {"type": "null"}]
    },
    "nullable_proceedings_facet": {
      "oneOf": [{"$ref": "#/$defs/proceedings_facet"}, {"type": "null"}]
    },
    "verified_milestone": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_milestone_id",
        "milestone_type",
        "scope",
        "date",
        "source_type",
        "source_url",
        "evidence_ids"
      ],
      "properties": {
        "candidate_milestone_id": {"$ref": "#/$defs/id"},
        "milestone_type": {
          "enum": [
            "conference_start",
            "conference_end",
            "acceptance_notification",
            "paper_list_expected",
            "proceedings_expected"
          ]
        },
        "scope": {"enum": ["conference", "main_track"]},
        "date": {"type": "string", "format": "date"},
        "source_type": {"enum": ["official", "archival"]},
        "source_url": {"$ref": "#/$defs/https_uri"},
        "evidence_ids": {
          "type": "array",
          "items": {"$ref": "#/$defs/id"},
          "minItems": 1,
          "uniqueItems": true
        }
      }
    }
  }
}
