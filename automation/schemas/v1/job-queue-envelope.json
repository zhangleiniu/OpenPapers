{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openpapers.local/schemas/v1/job-queue-envelope.json",
  "title": "OpenPapers Prefect typed queue envelope v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "work_pool_name",
    "work_queue_name",
    "job"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "work_pool_name": {"const": "openpapers-mac"},
    "work_queue_name": {
      "enum": [
        "openpapers-scrape",
        "openpapers-validation",
        "openpapers-codex"
      ]
    },
    "job": {"type": "object"}
  }
}
